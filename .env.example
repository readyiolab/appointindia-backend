NODE_ENV=development
PORT=3000
APP_NAME=job-portal-backend
API_VERSION=v1

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=Alok@123
DB_NAME=job_portal
DB_CONNECTION_LIMIT=10

# Upstash (preferred) — REST token is also the Redis password
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=

# Optional: direct Redis URL instead of Upstash vars
# REDIS_URL=rediss://default:token@your-instance.upstash.io:6379

# Local Redis fallback (used when Upstash vars are unset)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

JWT_ACCESS_SECRET=change_me_access
JWT_REFRESH_SECRET=change_me_refresh
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=job-portal-resumes

LOG_LEVEL=info
